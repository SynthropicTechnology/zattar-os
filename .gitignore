# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/dist-test
/test-results/
/tmp/
*.backup

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NUNCA commitar secrets - repositório público)
.env
.env.*
!.env.example
!.env.build.example
!.env.production
.env*.local.bak
.env.build

# docker secrets
docker-compose.portainer.yml

# symlink temporario criado pelo cloudron-deploy.sh (Dockerfile.cloudron -> Dockerfile)
Dockerfile

# MCP config (contém tokens de autenticação)
.mcp.json

# vercel
#.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Serwist (service worker gerado no build)
public/sw*
public/swe-worker*

# PDF.js worker (copied from node_modules during install)
**/public/pdfjs/

# Library folder (component library, not part of main app)
/library

# Build performance analysis results
scripts/results/build-performance/*.json
scripts/results/build-performance/history/
scripts/results/bundle-analysis/*.html
scripts/results/tst-acervo-geral/
scripts/results/depositos-uber-tst/
!scripts/results/build-performance/.gitkeep
!scripts/results/build-performance/history/.gitkeep
!scripts/results/bundle-analysis/.gitkeep

# Diagnósticos de banco (podem conter dados sensíveis)
DIAGNOSTICO_DISK_IO*.md

dados-cloudron.md
