{
  "css.customData": [
    ".vscode/css-custom-data.json"
  ],
  "css.lint.unknownAtRules": "ignore",
  "webhint.enableHints": {
    "no-inline-styles": "off"
  },
  "vscode-edge-devtools.webhint": false,
  "vscode-edge-devtools.mirrorEdits": false,
  // Desabilitar MCP Chrome DevTools (causa erros)
  "github.copilot.chat.mcp.enabled": true,
  "github.copilot.chat.mcp.servers": {
    "chromedevtools/chrome-devtools-mcp": {
      "enabled": false
    }
  },
  // Configuracao para extensao Lua ignorar arquivos de licenca e documentacao
  "Lua.workspace.ignoreDir": [
    "LICENSE",
    "TRADEMARK",
    "NOTICE"
  ],
  "Lua.diagnostics.globals": [],
  // TypeScript: usar workspace tsdk e ignorar tsconfigs de node_modules
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": [
      "node_modules"
    ]
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.validate.enabled": true,
  "js/ts.preferences.includePackageJsonAutoImports": "off",
  // Associacao de arquivos
  "files.associations": {
    "**/supabase/**/*.sql": "postgres",
    "LICENSE": "plaintext",
    "TRADEMARK": "plaintext",
    "NOTICE": "plaintext",
    "AGENTS": "markdown"
  },
  // Esconder arquivos problemáticos do explorer e watcher
  "files.exclude": {
    "**/node_modules/@copilotkit/**/tsconfig.json": true,
    "**/AppData/Local/Temp/**": true
  },
  "files.watcherExclude": {
    "**/node_modules/@copilotkit/**/tsconfig.json": true,
    "**/AppData/Local/Temp/**": true
  },
  // Desabilitar validacao MSSQL para migrations do Supabase (sao PostgreSQL)
  "[sql]": {
    "files.associations": {
      "**/supabase/migrations/**/*.sql": "postgres"
    }
  },
  "mssql.excludeFolders": [
    "**/supabase/**",
    "**/node_modules/**"
  ],
  "mssql.enableSqlDiagnostics": false,
  "typescript.autoClosingTags": false
}